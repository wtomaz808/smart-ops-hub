@page "/"

<PageTitle>AgentOpsHub</PageTitle>

<div class="landing">
    <section class="hero">
        <h1 class="hero-title">AgentOpsHub</h1>
        <p class="hero-subtitle">AI-powered operations platform for DevOps teams</p>
        <p class="hero-desc">
            Chat with specialized AI agents that have direct access to your GitHub repos, Azure resources,
            CI/CD pipelines, and more — all from a single command center.
        </p>
        <a href="agent/devops" class="hero-cta">Launch AgentHub →</a>
    </section>

    <section class="use-cases">
        <h2>What can you do?</h2>
        <div class="cards">
            <div class="card">
                <span class="card-icon">⚙️</span>
                <h3>DevOps</h3>
                <p>Manage GitHub PRs, deploy Azure resources, run pipelines, build .NET projects, and monitor infrastructure — all from one chat.</p>
            </div>
            <div class="card">
                <span class="card-icon">💼</span>
                <h3>BizOps</h3>
                <p>Draft emails, prepare meeting agendas, create status reports, and streamline corporate communications.</p>
            </div>
            <div class="card">
                <span class="card-icon">📚</span>
                <h3>Training &amp; Research</h3>
                <p>Research best practices, explore documentation, generate learning materials, and get AI-assisted analysis.</p>
            </div>
            <div class="card">
                <span class="card-icon">🎯</span>
                <h3>Personal</h3>
                <p>Check your calendar, manage tasks, and access personal productivity tools — plus a Help agent for platform questions.</p>
            </div>
        </div>
    </section>

    <section class="features">
        <h2>Key Features</h2>
        <ul>
            <li><strong>Multi-tool agents</strong> — Each agent combines multiple MCP servers for broad capability</li>
            <li><strong>File uploads</strong> — Attach code, configs, and docs directly in chat for AI analysis</li>
            <li><strong>Real-time streaming</strong> — Responses stream token-by-token via SignalR</li>
            <li><strong>Azure Government ready</strong> — Built for FedRAMP/IL5 compliance with managed identities</li>
            <li><strong>Extensible</strong> — Create custom agents with the tools you need</li>
        </ul>
    </section>
</div>

<style>
    .landing {
        max-width: 860px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
    }

    .hero {
        text-align: center;
        padding: 2.5rem 0 2rem;
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: #1a1a2e;
        margin: 0;
    }

    .hero-subtitle {
        font-size: 1.15rem;
        color: #0d6efd;
        font-weight: 600;
        margin: 0.25rem 0 1rem;
    }

    .hero-desc {
        font-size: 1rem;
        color: #495057;
        max-width: 560px;
        margin: 0 auto 1.5rem;
        line-height: 1.6;
    }

    .hero-cta {
        display: inline-block;
        padding: 0.75rem 2rem;
        background: #0d6efd;
        color: white;
        border-radius: 2rem;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: background 0.15s;
    }

    .hero-cta:hover { background: #0b5ed7; color: white; }

    .use-cases, .features {
        margin-top: 2.5rem;
    }

    .use-cases h2, .features h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 1rem;
    }

    .cards {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 0.75rem;
        padding: 1.25rem;
    }

    .card-icon { font-size: 1.5rem; }

    .card h3 {
        font-size: 1rem;
        font-weight: 700;
        margin: 0.5rem 0 0.35rem;
        color: #1a1a2e;
    }

    .card p {
        font-size: 0.85rem;
        color: #6c757d;
        line-height: 1.5;
        margin: 0;
    }

    .features ul {
        list-style: none;
        padding: 0;
    }

    .features li {
        padding: 0.5rem 0;
        font-size: 0.9rem;
        color: #495057;
        border-bottom: 1px solid #f1f3f5;
    }

    .features li:last-child { border-bottom: none; }

    @@media (max-width: 640px) {
        .cards { grid-template-columns: 1fr; }
        .hero-title { font-size: 2rem; }
    }
</style>
