@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        <div class="user-display">
            <span class="user-name">@context.User.Identity?.Name</span>
            <a class="nav-link logout-link" href="MicrosoftIdentity/Account/SignOut">Sign out</a>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="user-display">
            <a class="nav-link login-link" href="MicrosoftIdentity/Account/SignIn">Sign in</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .user-display {
        padding: 0.5rem 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        font-size: 0.85rem;
    }

    .user-name {
        color: rgba(255, 255, 255, 0.7);
        display: block;
        padding: 0.25rem 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .login-link, .logout-link {
        padding: 0.25rem 0 !important;
        font-size: 0.8rem;
    }
</style>
